# Copy to .env and fill in — never commit .env

# Required for OpenHands agent
ANTHROPIC_API_KEY=your_key_here

# Optional: override model
# FAULTBENCH_MODEL=claude-sonnet-4-20250514

# Optional: OpenHands server if not using docker-compose default
# OPENHANDS_HOST=http://localhost
# OPENHANDS_PORT=3000

# Optional: logging
# FAULTBENCH_LOG_FORMAT=json
# FAULTBENCH_LOG_LEVEL=DEBUG
