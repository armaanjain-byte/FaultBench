<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>FaultBench Report — {{ report_title }}</title>
    <style>
        :root {
            --bg: #fafafa;
            --card-bg: #ffffff;
            --text: #212121;
            --text-muted: #757575;
            --border: #e0e0e0;
            --green: #4CAF50;
            --red: #F44336;
            --orange: #FF9800;
            --blue: #2196F3;
        }

        * { margin: 0; padding: 0; box-sizing: border-box; }

        body {
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
            background: var(--bg);
            color: var(--text);
            line-height: 1.6;
            padding: 2rem;
            max-width: 1200px;
            margin: 0 auto;
        }

        header {
            text-align: center;
            padding: 2rem 0;
            border-bottom: 2px solid var(--border);
            margin-bottom: 2rem;
        }

        header h1 {
            font-size: 2rem;
            font-weight: 700;
            margin-bottom: 0.5rem;
        }

        header .subtitle {
            color: var(--text-muted);
            font-size: 1.1rem;
        }

        .meta-bar {
            display: flex;
            gap: 2rem;
            justify-content: center;
            flex-wrap: wrap;
            margin-top: 1rem;
            font-size: 0.9rem;
            color: var(--text-muted);
        }

        .meta-bar span { display: flex; align-items: center; gap: 0.3rem; }

        section {
            margin-bottom: 2.5rem;
        }

        h2 {
            font-size: 1.4rem;
            font-weight: 600;
            margin-bottom: 1rem;
            padding-bottom: 0.5rem;
            border-bottom: 1px solid var(--border);
        }

        h3 {
            font-size: 1.1rem;
            font-weight: 600;
            margin: 1.5rem 0 0.75rem;
        }

        /* Summary cards */
        .summary-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
            gap: 1rem;
            margin-bottom: 1.5rem;
        }

        .summary-card {
            background: var(--card-bg);
            border: 1px solid var(--border);
            border-radius: 8px;
            padding: 1.2rem;
            text-align: center;
        }

        .summary-card .value {
            font-size: 2rem;
            font-weight: 700;
            margin: 0.3rem 0;
        }

        .summary-card .label {
            font-size: 0.85rem;
            color: var(--text-muted);
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }

        .value.green { color: var(--green); }
        .value.red { color: var(--red); }
        .value.orange { color: var(--orange); }
        .value.blue { color: var(--blue); }

        /* Tables */
        table {
            width: 100%;
            border-collapse: collapse;
            background: var(--card-bg);
            border: 1px solid var(--border);
            border-radius: 8px;
            overflow: hidden;
            margin-bottom: 1.5rem;
        }

        thead th {
            background: #f5f5f5;
            font-weight: 600;
            text-align: left;
            padding: 0.75rem 1rem;
            border-bottom: 2px solid var(--border);
            font-size: 0.9rem;
            text-transform: uppercase;
            letter-spacing: 0.3px;
        }

        tbody td {
            padding: 0.65rem 1rem;
            border-bottom: 1px solid #f0f0f0;
        }

        tbody tr:last-child td { border-bottom: none; }
        tbody tr:hover { background: #f9f9f9; }

        .degradation-negative { color: var(--red); font-weight: 600; }
        .degradation-positive { color: var(--green); font-weight: 600; }

        /* Charts */
        .chart-container {
            background: var(--card-bg);
            border: 1px solid var(--border);
            border-radius: 8px;
            padding: 1rem;
            margin-bottom: 1.5rem;
            text-align: center;
        }

        .chart-container img {
            max-width: 100%;
            height: auto;
        }

        /* Task sections */
        .task-section {
            background: var(--card-bg);
            border: 1px solid var(--border);
            border-radius: 8px;
            padding: 1.5rem;
            margin-bottom: 1.5rem;
        }

        .task-section h3 {
            margin-top: 0;
        }

        /* Footer */
        footer {
            text-align: center;
            padding: 2rem 0 1rem;
            border-top: 1px solid var(--border);
            color: var(--text-muted);
            font-size: 0.85rem;
        }
    </style>
</head>
<body>

<header>
    <h1>🔧 FaultBench Report</h1>
    <p class="subtitle">{{ report_title }}</p>
    <div class="meta-bar">
        <span>📅 Generated: {{ generated_at }}</span>
        <span>🤖 Agent: {{ agent_name }}</span>
        <span>📊 Total Runs: {{ total_runs }}</span>
    </div>
</header>

<!-- Executive Summary -->
<section>
    <h2>Executive Summary</h2>
    <div class="summary-grid">
        <div class="summary-card">
            <div class="label">Tasks Analyzed</div>
            <div class="value blue">{{ tasks_analyzed }}</div>
        </div>
        <div class="summary-card">
            <div class="label">Mutations Tested</div>
            <div class="value orange">{{ mutations_tested }}</div>
        </div>
        <div class="summary-card">
            <div class="label">Mean Baseline Success</div>
            <div class="value green">{{ mean_baseline_success }}%</div>
        </div>
        <div class="summary-card">
            <div class="label">Mean Mutated Success</div>
            <div class="value red">{{ mean_mutated_success }}%</div>
        </div>
        <div class="summary-card">
            <div class="label">Worst Degradation</div>
            <div class="value red">{{ worst_degradation }}%</div>
        </div>
        <div class="summary-card">
            <div class="label">Avg Runtime Overhead</div>
            <div class="value orange">{{ avg_runtime_overhead }}x</div>
        </div>
    </div>
</section>

<!-- Overall Degradation Table -->
<section>
    <h2>Degradation Summary</h2>
    <table>
        <thead>
            <tr>
                <th>Task</th>
                <th>Mutation</th>
                <th>Baseline</th>
                <th>Mutated</th>
                <th>Degradation</th>
                <th>Runtime Overhead</th>
                <th>Retry Overhead</th>
            </tr>
        </thead>
        <tbody>
        {% for report in all_reports %}
            <tr>
                <td>{{ report.task_name }}</td>
                <td>{{ report.mutation_type }}</td>
                <td>{{ "%.0f"|format(report.baseline.success_rate * 100) }}%</td>
                <td>{{ "%.0f"|format(report.mutated.success_rate * 100) }}%</td>
                <td class="{{ 'degradation-negative' if report.success_rate_delta < 0 else 'degradation-positive' }}">
                    {{ "%+.0f"|format(report.success_rate_delta * 100) }}%
                </td>
                <td>{{ "%.2f"|format(report.runtime_overhead_ratio) }}x</td>
                <td>{{ "%.2f"|format(report.retry_overhead_ratio) }}x</td>
            </tr>
        {% endfor %}
        </tbody>
    </table>
</section>

<!-- Charts -->
{% if chart_paths %}
<section>
    <h2>Visualizations</h2>

    {% if chart_paths.success_rate %}
    <div class="chart-container">
        <h3>Success Rate Comparison</h3>
        <img src="{{ chart_paths.success_rate }}" alt="Success rate comparison chart">
    </div>
    {% endif %}

    {% if chart_paths.runtime %}
    <div class="chart-container">
        <h3>Runtime Comparison</h3>
        <img src="{{ chart_paths.runtime }}" alt="Runtime comparison chart">
    </div>
    {% endif %}

    {% if chart_paths.heatmap %}
    <div class="chart-container">
        <h3>Degradation Heatmap</h3>
        <img src="{{ chart_paths.heatmap }}" alt="Degradation heatmap">
    </div>
    {% endif %}

    {% if chart_paths.retries %}
    <div class="chart-container">
        <h3>Retry Distribution</h3>
        <img src="{{ chart_paths.retries }}" alt="Retry distribution chart">
    </div>
    {% endif %}
</section>
{% endif %}

<!-- Per-Task Detail -->
{% for task_name, reports in task_reports.items() %}
<section>
    <h2>{{ task_name }}</h2>

    {% for report in reports %}
    <div class="task-section">
        <h3>{{ report.mutation_type }}</h3>
        <table>
            <thead>
                <tr>
                    <th>Metric</th>
                    <th>Baseline</th>
                    <th>Mutated</th>
                    <th>Change</th>
                </tr>
            </thead>
            <tbody>
                <tr>
                    <td>Success Rate</td>
                    <td>{{ "%.1f"|format(report.baseline.success_rate * 100) }}%</td>
                    <td>{{ "%.1f"|format(report.mutated.success_rate * 100) }}%</td>
                    <td class="{{ 'degradation-negative' if report.success_rate_delta < 0 else 'degradation-positive' }}">
                        {{ "%+.1f"|format(report.success_rate_delta * 100) }}%
                    </td>
                </tr>
                <tr>
                    <td>Total Runs</td>
                    <td>{{ report.baseline.total_runs }}</td>
                    <td>{{ report.mutated.total_runs }}</td>
                    <td>—</td>
                </tr>
                <tr>
                    <td>Mean Runtime</td>
                    <td>{{ "%.1f"|format(report.baseline.mean_runtime_seconds) }}s</td>
                    <td>{{ "%.1f"|format(report.mutated.mean_runtime_seconds) }}s</td>
                    <td>{{ "%.2f"|format(report.runtime_overhead_ratio) }}x</td>
                </tr>
                <tr>
                    <td>Median Runtime</td>
                    <td>{{ "%.1f"|format(report.baseline.median_runtime_seconds) }}s</td>
                    <td>{{ "%.1f"|format(report.mutated.median_runtime_seconds) }}s</td>
                    <td>—</td>
                </tr>
                <tr>
                    <td>Mean Retries</td>
                    <td>{{ "%.1f"|format(report.baseline.mean_retry_count) }}</td>
                    <td>{{ "%.1f"|format(report.mutated.mean_retry_count) }}</td>
                    <td>{{ "%.2f"|format(report.retry_overhead_ratio) }}x</td>
                </tr>
                <tr>
                    <td>Mean Exceptions</td>
                    <td>{{ "%.1f"|format(report.baseline.mean_exception_count) }}</td>
                    <td>{{ "%.1f"|format(report.mutated.mean_exception_count) }}</td>
                    <td>—</td>
                </tr>
                {% if report.baseline.mean_tokens_used is not none %}
                <tr>
                    <td>Mean Tokens Used</td>
                    <td>{{ "%.0f"|format(report.baseline.mean_tokens_used) }}</td>
                    <td>{{ "%.0f"|format(report.mutated.mean_tokens_used) if report.mutated.mean_tokens_used is not none else "N/A" }}</td>
                    <td>—</td>
                </tr>
                {% endif %}
                {% if report.baseline.mean_first_failure_step is not none %}
                <tr>
                    <td>Mean First Failure Step</td>
                    <td>{{ "%.1f"|format(report.baseline.mean_first_failure_step) }}</td>
                    <td>{{ "%.1f"|format(report.mutated.mean_first_failure_step) if report.mutated.mean_first_failure_step is not none else "N/A" }}</td>
                    <td>—</td>
                </tr>
                {% endif %}
            </tbody>
        </table>
    </div>
    {% endfor %}
</section>
{% endfor %}

<footer>
    <p>Generated by FaultBench v{{ version }} — Stress-testing coding agents under adversarial conditions</p>
    <p>{{ generated_at }}</p>
</footer>

</body>
</html>
